# =============================================================================
# Copy to ".env" at this repo root and replace placeholder values.
# Do not commit .env — it is listed in .gitignore.
# python-dotenv loads .env for Python scripts (see bootstrap_env.py).
# Docker Compose for Logstash loads this file via Logstash_input/docker-compose.yml.
#
# You do not need to fill every variable — only the section(s) for tools you run.
# =============================================================================

# -----------------------------------------------------------------------------
# validate_migration.py  |  poll_reindex_task.py
# Required: hosts + Elastic auth. Source uses SigV4 unless USER+PASSWORD are set.
# -----------------------------------------------------------------------------
SOURCE_OPENSEARCH_HOST=https://search-your-domain.region.es.amazonaws.com:443
DEST_ELASTIC_HOST=https://your-deployment.es.region.aws.found.io
DEST_ELASTIC_API_KEY=replace-with-elastic-api-key-base64-or-id-secret

# Alternative Elastic auth (comment out DEST_ELASTIC_API_KEY if you use this):
# DEST_ELASTIC_USER=elastic
# DEST_ELASTIC_PASSWORD=replace-with-password

# Optional: OpenSearch fine-grained user (if set, SigV4 is NOT used for source)
# SOURCE_OPENSEARCH_USER=opensearch-master-user
# SOURCE_OPENSEARCH_PASSWORD=replace-with-opensearch-password

# Required for SigV4 to Amazon OpenSearch (validate_migration source, Proxy, local AWS CLI):
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Logstash (Logstash_input/docker-compose.yml)
# Reuses SOURCE_OPENSEARCH_* and AWS_REGION from above.
# Default service: set ELASTIC_CLOUD_* — get these from Elastic Cloud deployment UI.
# -----------------------------------------------------------------------------
LOGSTASH_SOURCE_INDEX=source-index-name
LOGSTASH_DEST_INDEX=destination-index-name
ELASTIC_CLOUD_ID=deployment_name:Ynk4dFpHRnVkSEoH...replace-with-full-cloud-id
ELASTIC_CLOUD_AUTH=elastic:replace-with-elastic-cloud-user-password

# For "docker compose --profile apikey up" instead of cloud_id/cloud_auth:
# Use DEST_ELASTIC_HOST and DEST_ELASTIC_API_KEY (already set in validate_migration section).

# Optional JVM for Logstash (uncomment and add to docker-compose.yml environment if needed):
# LS_JAVA_OPTS=-Xmx2g -Xms2g

# -----------------------------------------------------------------------------
# Proxy (Proxy/app.py) — HTTP → OpenSearch with SigV4
# -----------------------------------------------------------------------------
# OPENSEARCH_ENDPOINT=https://search-your-domain.region.es.amazonaws.com
# PROXY_LISTEN=0.0.0.0:9200
# PROXY_USER=proxy-basic-auth-user
# PROXY_PASSWORD=replace-with-proxy-password

# -----------------------------------------------------------------------------
# Optional: integration test (pytest tests/test_integration_validate.py)
# Set OSS_MIGRATION_INTEGRATION=1 and fill these to run against real clusters.
# -----------------------------------------------------------------------------
# OSS_MIGRATION_INTEGRATION=1
# SOURCE_VALIDATION_INDEX=my-smoke-source-index
# DEST_VALIDATION_INDEX=my-smoke-dest-index
# OSS_MIGRATION_SAMPLE_SIZE=3
# OSS_MIGRATION_SAMPLE_MODE=head
# OSS_MIGRATION_TIMEOUT=120
# For sample_mode=time_stratified:
# OSS_MIGRATION_TIME_FIELD=@timestamp
# OSS_MIGRATION_TIME_BUCKETS=8
